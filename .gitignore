# ==========================================
# 1. 依赖包（绝对不能提交，体积大且可自动生成）
# ==========================================
node_modules/
jspm_packages/

# ==========================================
# 2. 缓存与日志（本地运行产生的垃圾文件）
# ==========================================
.npm
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# 3. 本地环境变量与私密配置（切勿开源，防止密钥泄露）
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# 4. 编译/打包输出（如果是 TypeScript 或需要打包的工具）
# ==========================================
dist/
build/
out/
.cache/

# ==========================================
# 5. 操作系统与编辑器生成的缓存
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
